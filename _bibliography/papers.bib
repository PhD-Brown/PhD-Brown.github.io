@unpublished{baker2026astrospectro,
  title        = {Interpretable Machine Learning for Stellar Spectral Classification with {LAMOST} {DR5} and {Gaia} {DR3}},
  author       = {Baker, Alex},
  year         = {2026},
  abbr         = {In prep.},
  note         = {Manuscript in preparation},
  abstract     = {This work develops an interpretable machine-learning pipeline for stellar spectral classification using physics-based spectroscopic descriptors extracted from LAMOST DR5 spectra cross-matched with Gaia DR3. The pipeline combines feature engineering, supervised classification, dimensionality reduction, and SHAP-based interpretability to study which spectral features drive model decisions. Current results suggest that metallicity-sensitive indicators, including Ca II H&K and Mg b, play a major role in the learned classification structure, alongside classical temperature-sensitive Balmer features.},
  code         = {https://github.com/PhD-Brown/AstroSpectro},
  website      = {https://phd-brown.github.io/AstroSpectro/},
  selected     = {true}
}

@unpublished{baker2026phy3500,
  title        = {Réduction de dimension et interprétabilité appliquées aux spectres stellaires {LAMOST} {DR5}},
  author       = {Baker, Alex and Jean, Justine and Caillat, Nérimantas},
  year         = {2026},
  abbr         = {Course},
  note         = {Course report and symposium contribution, PHY-3500, Université Laval, Winter 2026. Supervised by Prof. Antoine Allard.},
  abstract     = {Course research project presented in the context of PHY-3500 at Université Laval. The project applies dimensionality-reduction methods and interpretability tools to LAMOST DR5 stellar spectra in order to compare PCA, UMAP, t-SNE, and autoencoder-based representations of astrophysical feature space. The work builds on the AstroSpectro pipeline and focuses on the physical interpretation of low-dimensional spectral structure.},
  code         = {https://github.com/PhD-Brown/AstroSpectro},
  selected     = {false}
}